FROM golang:1.25-bookworm AS builder
WORKDIR /src/grpc
COPY grpc/go.mod grpc/go.sum ./
RUN go mod download
COPY grpc .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/transcoder-grpc ./main.go

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /out/transcoder-grpc /usr/local/bin/transcoder-grpc
EXPOSE 8099
ENTRYPOINT ["/usr/local/bin/transcoder-grpc"]
