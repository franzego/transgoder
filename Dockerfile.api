FROM golang:1.25-bookworm AS builder
WORKDIR /src
COPY go.mod go.sum ./
# Include local replaced module manifests before dependency download.
COPY grpc/go.mod grpc/go.sum ./grpc/
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/transcoder-api ./cmd/main.go

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=builder /out/transcoder-api /usr/local/bin/transcoder-api
COPY web ./web
COPY docs ./docs
EXPOSE 8084
ENTRYPOINT ["/usr/local/bin/transcoder-api"]
